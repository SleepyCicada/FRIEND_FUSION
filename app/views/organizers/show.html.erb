<div class="organizer-profile-page">
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 2.5rem;">
    <div class="row">
      <div class="col-lg-10 mx-auto">

        <!-- Go Back Button -->
        <div class="go-back-container">
          <button class="go-back-button" onclick="goBack()">
            <!-- Optional: back arrow icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 8a.5.5 0 0 1-.5.5H2.707l4.147 4.146a.5.5 0 0 1-.708.708l-5-5a.5.5 0 0 1 0-.708l5-5a.5.5 0 1 1 .708.708L2.707 7.5H14.5A.5.5 0 0 1 15 8z"/>
            </svg>
          </button>
        </div>

       <script>
        function goBack() {
          if (document.referrer) {
            window.history.back();
            setTimeout(() => {
              // If still on same page, fallback
              if (document.referrer === "") {
                window.location.href = "/";
              }
            }, 100);
          } else {
            window.location.href = "/";
          }
        }
      </script>

        <!-- Organizer Hero Section -->
        <div class="organizer-hero mb-5">
          <div class="organizer-avatar-large">
            <%= @organizer.name&.first&.upcase || '?' %>
          </div>
          <h1 class="organizer-name"><%= @organizer.name %></h1>
          <p class="organizer-subtitle">Event Organizer</p>

          <!-- Stats Grid -->
          <div class="organizer-stats">
            <div class="stat-card">
              <div class="stat-icon">⭐</div>
              <div class="stat-value"><%= @organizer.average_organizer_rating %></div>
              <div class="stat-label">Average Rating</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">🎉</div>
              <div class="stat-value"><%= @organizer.events_organized_count %></div>
              <div class="stat-label">Events Organized</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">👥</div>
              <div class="stat-value"><%= @organizer.total_attendees_hosted %></div>
              <div class="stat-label">Total Attendees</div>
            </div>
          </div>
        </div>

        <!-- Past Events Section -->
<% if @organized_events.any? %>
  <div class="organizer-section">
    <h2 class="organizer-section-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
        <path d="M1 2a2 2 0 0 1 2-2h1v1a1 1 0 0 0 2 0V0h4v1a1 1 0 0 0 2 0V0h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V2zm1 3v8a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V5H2z"/>
      </svg>
      Past Events
    </h2>

    <div class="events-table">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Attendees</th>
            <th>Rating</th>
          </tr>
        </thead>

        <tbody>
          <% @organized_events.each do |event| %>
            <tr>
              <td data-label="Event">
                <%= link_to event.title, event_path(event), class: "event-link" %>
              </td>

              <td data-label="Date">
                <%= event.date_time&.strftime("%b %d, %Y") || "TBD" %>
              </td>

              <td data-label="Attendees">
                <span class="badge badge-attendees">
                  <%= event.confirmations.count %> attendees
                </span>
              </td>

              <td data-label="Rating">
                <% if event.feedback_count > 0 %>
                  <span class="badge badge-rating">
                    ⭐ <%= event.average_rating %> (<%= event.feedback_count %>)
                  </span>
                <% else %>
                  <span class="text-muted">No reviews yet</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

        <!-- Top Reviews Section -->
        <% if @top_reviews.any? %>
          <div class="organizer-section">
            <h2 class="organizer-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
              </svg>
              Top Reviews
            </h2>
            <div class="reviews-list">
              <% @top_reviews.each do |review| %>
                <div class="review-card">
                  <div class="review-header">
                    <div class="review-user-info">
                      <div class="review-avatar">
                        <%= review.user.name&.first&.upcase || '?' %>
                      </div>
                      <div>
                        <div class="review-user-name"><%= review.user.name %></div>
                        <div class="review-event-name">
                          <%= link_to review.event.title, event_path(review.event), class: "review-event-link" %>
                        </div>
                      </div>
                    </div>
                    <div class="review-rating">
                      <%= "⭐" * review.rating %>
                    </div>
                  </div>
                  <p class="review-comment"><%= review.comment %></p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</div>
